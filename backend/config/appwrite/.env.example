# Configuración de Appwrite para Plataforma de Capacitación
# Copia este archivo como .env y configura los valores según tu VPS

# =============================================================================
# CONFIGURACIÓN GENERAL DE APPWRITE
# =============================================================================

# Dominio principal donde estará alojado Appwrite
_APP_DOMAIN=localhost

# Dominio para el console de Appwrite (panel de administración)
_APP_DOMAIN_TARGET=localhost

# URL del sitio web principal (tu plataforma de capacitación)
_APP_REDIS_HOST=redis
_APP_REDIS_PORT=6379
_APP_REDIS_USER=
_APP_REDIS_PASS=

# Configuración de entorno (production o staging)
_APP_ENV=production

# Opciones de configuración regional
_APP_OPTIONS_LOCALE=es
_APP_OPTIONS_ROUTER=1
_APP_OPTIONS_ABUSE=1
_APP_OPTIONS_FORCE_HTTPS=1

# Tamaño máximo de archivo (en bytes) - 50MB por defecto
_APP_STORAGE_LIMIT=52428800

# Límite de funciones serverless
_APP_FUNCTIONS_SIZE_LIMIT=30000000
_APP_FUNCTIONS_TIMEOUT=900
_APP_FUNCTIONS_CONTAINERS=10
_APP_FUNCTIONS_CPUS=0
_APP_FUNCTIONS_MEMORY=0
_APP_FUNCTIONS_SWAP=0
_APP_FUNCTIONS_RUNTIMES=node-16.0,node-18.0,node-20.0,node-21.0,php-8.0,php-8.1,php-8.2,php-8.3,python-3.8,python-3.9,python-3.10,python-3.11,python-3.12,ruby-3.0,ruby-3.1,ruby-3.2,ruby-3.3,.NET-6.0,.NET-7.0,.NET-8.0,java-8.0,java-11.0,java-17.0,java-21.0,swift-5.5,swift-5.6,swift-5.7,swift-5.8,swift-5.9,kotlin-1.6,kotlin-1.7,kotlin-1.8,kotlin-1.9,go-1.21,go-1.22

# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# =============================================================================

# MariaDB (recomendado)
_DB_HOST=mariadb
_DB_PORT=3306
_DB_SCHEMA=appwrite
_DB_USER=root
_DB_PASS=password_segura_appwrite
_DB_CHARSET=utf8mb4

# Alternativa: PostgreSQL
#_DB_HOST=postgres
#_DB_PORT=5432
#_DB_SCHEMA=appwrite
#_DB_USER=root
#_DB_PASS=password_segura_appwrite
#_DB_CHARSET=utf8

# =============================================================================
# CONFIGURACIÓN DE AUTENTICACIÓN
# =============================================================================

# Clave secreta para encriptación (CAMBIAR EN PRODUCCIÓN)
_APP_SYSTEM_SECRET_KEY=tu_clave_secreta_muy_segura_aqui_32_caracteres

# Clave de encriptación de funciones
_APP_SYSTEM_RESPONSE_FORMAT=

# Configuración de sesiones
_APP_CONSOLE_WHITELIST_ROOT=enabled
_APP_CONSOLE_WHITELIST_EMAILS=
_APP_CONSOLE_WHITELIST_IPS=

# =============================================================================
# CONFIGURACIÓN DE EMAIL (SMTP)
# =============================================================================

# SMTP para envío de emails del sistema
_APP_SMTP_HOST=smtp.gmail.com
_APP_SMTP_PORT=587
_APP_SMTP_SECURE=tls
_APP_SMTP_USERNAME=tu_email@gmail.com
_APP_SMTP_PASSWORD=tu_password_de_aplicacion
_APP_SMTP_REPLY_TO=
_APP_SMTP_FROM_NAME="Plataforma de Capacitación"
_APP_SMTP_FROM_EMAIL=noreply@tudominio.com

# =============================================================================
# CONFIGURACIÓN DE STORAGE
# =============================================================================

# Proveedor de almacenamiento (local o s3)
_APP_STORAGE_DEVICE=local

# Si usas Amazon S3
#_APP_STORAGE_S3_ACCESS_KEY=tu_access_key
#_APP_STORAGE_S3_SECRET=tu_secret_key
#_APP_STORAGE_S3_REGION=us-east-1
#_APP_STORAGE_S3_BUCKET=tu_bucket_name

# =============================================================================
# CONFIGURACIÓN DE SSL/HTTPS
# =============================================================================

# Email para Let's Encrypt (certificados SSL gratuitos)
_APP_SYSTEM_SECURITY_EMAIL_ADDRESS=admin@tudominio.com

# =============================================================================
# CONFIGURACIÓN DE LOGS Y MONITOREO
# =============================================================================

# Nivel de logging (debug, info, warning, error)
_APP_LOGGING_PROVIDER=
_APP_LOGGING_CONFIG=

# Configuración de errores
_APP_ERROR_HANDLER=1

# =============================================================================
# CONFIGURACIÓN DE COLAS Y WORKERS
# =============================================================================

# Configuración de workers para tareas en segundo plano
_APP_USAGE_STATS=enabled
_APP_WORKER_PER_CORE=6

# =============================================================================
# CONFIGURACIÓN DE LÍMITES Y SEGURIDAD
# =============================================================================

# Límites de rate limiting
_APP_LIMITS_USERS=1000
_APP_LIMITS_MESSAGES_PER_DAY=1000

# Configuración de Abuse
_APP_ABUSE_LIMIT=1000

# =============================================================================
# NOTAS IMPORTANTES
# =============================================================================
# 
# 1. CAMBIAR TODOS LOS VALORES DE EJEMPLO EN PRODUCCIÓN
# 2. Usar contraseñas seguras (mínimo 16 caracteres)
# 3. Configurar SMTP correctamente para envío de emails
# 4. Configurar dominios correctamente
# 5. Hacer backup de este archivo de forma segura
# 
# =============================================================================
