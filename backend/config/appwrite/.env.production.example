# =============================================================================
# CONFIGURACIÓN DE PRODUCCIÓN - APPWRITE
# Plataforma de Capacitación y Apoyo para Socios
# =============================================================================
# 
# Copiar este archivo como .env y cambiar TODOS los valores
# 
# =============================================================================

# =============================================================================
# CONFIGURACIÓN GENERAL
# =============================================================================

# Entorno (development | production)
_APP_ENV=production

# Idioma por defecto
_APP_LOCALE=es

# Habilitar protección contra abuso
_APP_OPTIONS_ABUSE=enabled

# Forzar HTTPS (recomendado para producción)
_APP_OPTIONS_FORCE_HTTPS=enabled

# =============================================================================
# DOMINIO Y SSL
# =============================================================================

# Dominio principal de Appwrite (sin http:// o https://)
# Ejemplo: api.tudominio.com
_APP_DOMAIN=tudominio.com

# Dominio para el console
# Ejemplo: console.tudominio.com
_APP_CONSOLE_DOMAIN=console.tudominio.com

# Email para Let's Encrypt (requerido para SSL automático)
_APP_SYSTEM_SECURITY_EMAIL_ADDRESS=admin@tudominio.com

# =============================================================================
# SEGURIDAD
# =============================================================================

# Clave secreta - CAMBIAR POR UNA CLAVE SEGURA DE 32+ CARACTERES
# Generar con: openssl rand -hex 32
_APP_SYSTEM_SECRET_KEY=cambia_esta_clave_secreta_por_una_segura_de_32_caracteres_minimo

# =============================================================================
# BASE DE DATOS (MariaDB)
# =============================================================================

# Host de la base de datos (nombre del contenedor Docker)
_APP_DB_HOST=mariadb

# Puerto de la base de datos
_APP_DB_PORT=3306

# Nombre de la base de datos
_APP_DB_SCHEMA=appwrite

# Usuario de la base de datos
_APP_DB_USER=root

# Contraseña de la base de datos - CAMBIAR
_APP_DB_PASS=tu_password_segura_de_base_de_datos

# =============================================================================
# REDIS (CACHE)
# =============================================================================

# Host de Redis
_APP_SYSTEM_REDIS_HOST=redis

# Puerto de Redis
_APP_SYSTEM_REDIS_PORT=6379

# Usuario de Redis (vacío si no hay autenticación)
_APP_SYSTEM_REDIS_USER=

# Contraseña de Redis (vacío si no hay autenticación)
_APP_SYSTEM_REDIS_PASS=

# =============================================================================
# EMAIL (SMTP)
# =============================================================================

# Host del servidor SMTP
# Para Gmail: smtp.gmail.com
# Para SendGrid: smtp.sendgrid.net
# Para Mailgun: smtp.mailgun.org
_APP_SMTP_HOST=smtp.gmail.com

# Puerto SMTP
# 587 para TLS, 465 para SSL
_APP_SMTP_PORT=587

# Seguridad SMTP (tls | ssl)
_APP_SMTP_SECURE=tls

# Usuario SMTP (generalmente tu email)
_APP_SMTP_USERNAME=tu_email@gmail.com

# Contraseña SMTP
# Para Gmail: usar App Password (https://myaccount.google.com/security)
_APP_SMTP_PASSWORD=tu_app_password_de_gmail

# Nombre remitente de emails
_APP_SYSTEM_EMAIL_NAME=Plataforma de Capacitación

# Email remitente
_APP_SYSTEM_EMAIL_ADDRESS=noreply@tudominio.com

# =============================================================================
# ALMACENAMIENTO
# =============================================================================

# Límite de tamaño de archivos (en bytes)
# 52428800 = 50MB
_APP_STORAGE_LIMIT=52428800

# Dispositivo de almacenamiento (local | s3 | do | wasabi | backblaze | linode)
_APP_STORAGE_DEVICE=local

# Configuración S3 (si usas almacenamiento en la nube)
# _APP_STORAGE_S3_ACCESS_KEY=
# _APP_STORAGE_S3_SECRET=
# _APP_STORAGE_S3_REGION=us-east-1
# _APP_STORAGE_S3_BUCKET=

# =============================================================================
# FUNCIONES SERVERLESS
# =============================================================================

# Límite de tamaño de funciones (en bytes)
# 30000000 = 30MB
_APP_FUNCTIONS_SIZE_LIMIT=30000000

# Timeout de funciones (en segundos)
_APP_FUNCTIONS_TIMEOUT=900

# Número máximo de contenedores de funciones
_APP_FUNCTIONS_CONTAINERS=10

# CPUs asignadas a cada función (0 = sin límite)
_APP_FUNCTIONS_CPUS=0

# Memoria asignada a cada función (0 = sin límite)
_APP_FUNCTIONS_MEMORY=0

# Swap asignada a cada función (0 = sin límite)
_APP_FUNCTIONS_SWAP=0

# Runtimes disponibles
_APP_FUNCTIONS_RUNTIMES=node-16.0,node-18.0,node-20.0,php-8.0,php-8.1,php-8.2,python-3.8,python-3.9,python-3.10,python-3.11,ruby-3.0,ruby-3.1,ruby-3.2

# Umbral de inactividad en minutos
_APP_FUNCTIONS_INACTIVE_THRESHOLD=60

# Docker Hub credentials (para evitar rate limits)
DOCKERHUB_PULL_USERNAME=
DOCKERHUB_PULL_PASSWORD=

# =============================================================================
# ESTADÍSTICAS Y MONITOREO
# =============================================================================

# Habilitar estadísticas de uso
_APP_USAGE_STATS=enabled

# Host de InfluxDB
_APP_INFLUXDB_HOST=influxdb

# Puerto de InfluxDB
_APP_INFLUXDB_PORT=8086

# =============================================================================
# LOGGING
# =============================================================================

# Proveedor de logging (vacío para usar el por defecto)
_APP_LOGGING_PROVIDER=

# Configuración de logging
_APP_LOGGING_CONFIG=

# =============================================================================
# MANTENIMIENTO
# =============================================================================

# Intervalo de mantenimiento (en segundos)
# 86400 = 24 horas
_APP_MAINTENANCE_INTERVAL=86400

# Retención de caché (en segundos)
# 2592000 = 30 días
_APP_MAINTENANCE_RETENTION_CACHE=2592000

# Retención de ejecuciones (en segundos)
# 1209600 = 14 días
_APP_MAINTENANCE_RETENTION_EXECUTION=1209600

# Retención de auditoría (en segundos)
# 1209600 = 14 días
_APP_MAINTENANCE_RETENTION_AUDIT=1209600

# Retención de abuso (en segundos)
# 86400 = 1 día
_APP_MAINTENANCE_RETENTION_ABUSE=86400

# Retención de programaciones (en segundos)
# 86400 = 1 día
_APP_MAINTENANCE_RETENTION_SCHEDULES=86400

# =============================================================================
# MIGRACIONES
# =============================================================================

# Habilitar migraciones automáticas
_APP_MIGRATIONS_FIREBASE_CLIENT_ID=
_APP_MIGRATIONS_FIREBASE_CLIENT_SECRET=

# =============================================================================
# NOTAS IMPORTANTES
# =============================================================================

# 1. CAMBIAR TODOS LOS VALORES DE EJEMPLO
#    - _APP_SYSTEM_SECRET_KEY: Generar clave segura
#    - _APP_DB_PASS: Contraseña segura para MariaDB
#    - _APP_SMTP_*: Configurar tu proveedor de email

# 2. DOMINIO
#    - Configurar DNS A record apuntando a tu VPS
#    - El SSL se configura automáticamente con Let's Encrypt

# 3. EMAIL
#    - Para Gmail, crear App Password en:
#      https://myaccount.google.com/security

# 4. BACKUPS
#    - Configurar el script de backup en cron
#    - 0 2 * * * /home/usuario/appwrite/backup.sh

# 5. FIREWALL
#    - Abrir puertos: 80, 443
#    - Cerrar puerto 80 después de obtener SSL si se desea

# =============================================================================
# VERIFICACIÓN
# =============================================================================

# Para verificar que Appwrite está funcionando:
# curl -I https://tu-dominio.com/v1/health
