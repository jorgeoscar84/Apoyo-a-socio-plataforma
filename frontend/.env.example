# Configuración del Frontend
# Plataforma de Capacitación y Apoyo para Socios

# =============================================================================
# APPWRITE CONFIGURATION
# =============================================================================

# URL de tu instancia de Appwrite (cambiar cuando tengas el VPS configurado)
NEXT_PUBLIC_APPWRITE_ENDPOINT=http://localhost/v1

# Project ID de Appwrite (obtenido del Console)
NEXT_PUBLIC_APPWRITE_PROJECT_ID=tu_project_id

# API Key de Appwrite (crear en Console > API Keys)
# Usar una key con permisos de lectura para el frontend
NEXT_PUBLIC_APPWRITE_API_KEY=tu_api_key_frontend

# Database ID de Appwrite (obtenido del Console)
NEXT_PUBLIC_APPWRITE_DATABASE_ID=plataforma_capacitacion

# =============================================================================
# NEXT.JS CONFIGURATION
# =============================================================================

# URL base de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL base para producción (cambiar al desplegar)
NEXT_PUBLIC_APP_PROD_URL=https://tudominio.com

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Nombre de la aplicación
NEXT_PUBLIC_APP_NAME=Plataforma de Capacitación y Apoyo para Socios

# Descripción de la aplicación
NEXT_PUBLIC_APP_DESCRIPTION=Plataforma educativa y de apoyo para socios

# =============================================================================
# DEFAULT SETTINGS
# =============================================================================

# Rol por defecto para nuevos usuarios (SOCIO | ASESOR | ADMIN)
# Solo para desarrollo, en producción se determina por backend
NEXT_PUBLIC_DEFAULT_ROLE=SOCIO

# =============================================================================
# NOTAS IMPORTANTES
# =============================================================================

# 1. Copiar este archivo como .env antes de usar:
#    cp .env.example .env

# 2. CAMBIAR todos los valores de ejemplo con los valores reales
#    - NEXT_PUBLIC_APPWRITE_ENDPOINT: URL de tu Appwrite
#    - NEXT_PUBLIC_APPWRITE_PROJECT_ID: ID del proyecto
#    - NEXT_PUBLIC_APPWRITE_API_KEY: API Key del frontend
#    - NEXT_PUBLIC_APPWRITE_DATABASE_ID: ID de la base de datos

# 3. Los valores NEXT_PUBLIC_* están disponibles en el navegador
#    (client-side)

# 4. Mantener este archivo seguro (no incluirlo en git)
#    Agregar .env a .gitignore

# 5. Para obtener los IDs necesarios:
#    - Ingresar a Appwrite Console
#    - Crear un proyecto y copiar el Project ID
#    - Crear una base de datos y copiar el Database ID
#    - Crear una API Key y copiarla
